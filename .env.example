# lilasp-webgis environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# JWT shared secret — all qwc-services must use the same value
# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_HEX_64

# ConfigDB password (internal PostgreSQL for qwc config/permissions)
CONFIG_DB_PASSWORD=REPLACE_WITH_RANDOM

# qwc_service role password on host PostgreSQL
# See /root/.secrets/qwc-credentials on the server
QWC_SERVICE_DB_PASSWORD=REPLACE_WITH_ACTUAL

# QFieldCloud API base URL (used by auth-adapter)
QFC_BASE_URL=https://qfield.lilasp.de/api/v1

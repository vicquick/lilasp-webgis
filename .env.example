# ── Postgres metadata DB ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=planportal
POSTGRES_USER=planportal
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://planportal:changeme@postgres:5432/planportal

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── py-qgis-server ───────────────────────────────────────────────────────
QGSRV_SERVER_WORKERS=4
QGSRV_SERVER_TIMEOUT=300
QGSRV_SERVER_PROXY_URL=https://webgis.lilasp.de/qgisserver
QGSRV_CACHE_SIZE=30
QGSRV_LOGGING_LEVEL=INFO

# ── Indexer ──────────────────────────────────────────────────────────────
QGS_ROOT=/srv/gis
TILES_ROOT=/srv/tiles
WEB_SERVICES_JSON=/srv/web/services.json
PYQGIS_URL=http://qgisserver:8080
INDEXER_DEBOUNCE_SECONDS=2

# ── QFieldCloud sync (optional) ──────────────────────────────────────────
QFC_BASE_URL=https://qfield.lilasp.de/api/v1
QFC_ADMIN_TOKEN=
QFC_SYNC_INTERVAL_MINUTES=15

# ── Authentik / forward-auth (prod only — set in Coolify) ────────────────
AUTHENTIK_HOST=https://auth.lilasp.de
AUTH_GATEWAY_BIND=0.0.0.0:5000

# ── auth-gateway login flow ──────────────────────────────────────────────
# HMAC signing secret for the session cookie. Generate with:
#   openssl rand -hex 32
# REQUIRED — auth-gateway refuses to start otherwise.
WEBGIS_AUTH_SECRET=
WEBGIS_AUTH_TTL_DAYS=7

# ── Frontend ─────────────────────────────────────────────────────────────
WEB_PUBLIC_BASE_URL=https://webgis.lilasp.de
WEB_QGIS_BASE=/qgisserver
WEB_TILES_BASE=/tiles
WEB_WHOAMI=/whoami
WEB_SERVICES_JSON_URL=/services.json
